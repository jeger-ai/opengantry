#!/usr/bin/env bash
# OpenGantry pre-commit: advisory TMVC path guard (staged index vs mission roots).
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

if [[ -f dist/cli/index.js ]]; then
  GANTRY_CLI=(node dist/cli/index.js)
elif command -v gantry >/dev/null 2>&1; then
  GANTRY_CLI=(gantry)
else
  echo "pre-commit: gantry not found — run: npm run build" >&2
  exit 1
fi

mission=""
if mission="$(scripts/gxt-resolve-mission.sh 2>/dev/null)"; then
  :
else
  echo "pre-commit: no pinned mission — skipping TMVC guard (advisory)" >&2
  exit 0
fi

echo "pre-commit: gantry tmvc guard --mission ${mission} (advisory default)" >&2
"${GANTRY_CLI[@]}" tmvc guard --mission "$mission"
exit 0
