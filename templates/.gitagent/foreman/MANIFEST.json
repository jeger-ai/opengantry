{
  "schema_version": "0.5.0",
  "skills": {
    "ui": {
      "desc": "UI components and styles within declared roots.",
      "trust_threshold": "Tier-1",
      "tmvc_roots": ["src/components/", "src/styles/"],
      "forbidden_zones": [".gitagent/", "src/auth/", "src/core/", "src/db/schema/"]
    },
    "logic": {
      "desc": "Application logic and utilities within declared roots.",
      "trust_threshold": "Tier-2",
      "tmvc_roots": ["src/lib/", "src/utils/"],
      "forbidden_zones": [".gitagent/", "src/auth/", "src/core/", "src/db/schema/"]
    },
    "gantry": {
      "desc": "gantry CLI delivery, lib layers, and unit tests (OpenGantry specimen).",
      "trust_threshold": "Tier-2",
      "tmvc_roots": ["src/cli/"],
      "forbidden_zones": [".gitagent/foreman/", ".gitagent/planner/RULES.md"]
    },
    "substrate": {
      "desc": "Reserved for high-risk substrate work; requires Planner mission.",
      "trust_threshold": "Tier-3",
      "tmvc_roots": [],
      "forbidden_zones": []
    }
  },
  "path_risks": {
    "src/cli/": "Tier-2",
    ".gitagent/": "Tier-3",
    "src/core/": "Tier-3",
    "src/auth/": "Tier-3",
    "src/db/schema/": "Tier-3"
  },
  "risk_keywords": ["refactor", "migrate", "delete", "security", "schema"],
  "perimeter_protected": [
    "**/.gxt-skill.yaml",
    ".gitagent/foreman/MANIFEST.json",
    ".gitagent/planner/RULES.md"
  ]
}
