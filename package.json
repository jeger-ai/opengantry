{
  "name": "@jeger-ai/opengantry",
  "version": "2.3.0",
  "description": "Open Source Gantry — vendor-neutral GXT substrate and Gantry CLI for local git-native agent governance",
  "type": "module",
  "bin": {
    "gantry": "dist/cli/index.js",
    "gapman": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "!dist/cli/tests",
    "templates",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "gen:version": "node scripts/gen-version.mjs",
    "gen:catalog": "node scripts/gen-asset-catalog.mjs",
    "gen:dogfood": "node scripts/gen-dogfood.mjs",
    "build": "npm run gen:version && npm run gen:catalog && npm run gen:dogfood && tsc",
    "gapman": "node dist/cli/index.js",
    "lint": "eslint src/cli/**/*.ts",
    "check:changed": "./scripts/check-changed-code.sh",
    "validate": "./scripts/dev-validate.sh",
    "prepublishOnly": "npm run build && npm test",
    "pack:check": "./scripts/npm-pack-check.sh",
    "test": "npm run build && node --test \"dist/cli/tests/**/*.test.js\"",
    "examples:benchmark": "node examples/benchmark-agent/run-benchmark.mjs",
    "gantry": "node dist/cli/index.js"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "gxt",
    "gantry",
    "gantry-cli",
    "open-source-gantry",
    "git-hooks",
    "ai-agents",
    "governance",
    "devtools"
  ],
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.28.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.33.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "yaml": "^2.6.1",
    "zod": "^3.25.76"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeger-ai/opengantry.git"
  },
  "author": "Juergen Eger",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/jeger-ai/opengantry/issues"
  },
  "homepage": "https://github.com/jeger-ai/opengantry#readme"
}
